# Backend API URLs (use local or cloud endpoints)
# Local: http://localhost:5001  |  Cloud: https://backendttl.onrender.com
VITE_API_URL=http://localhost:5001
# Local: http://localhost:8000  |  Cloud: your-node-server-url
VITE_TTS_URL=http://localhost:8000

# Dev server port
PORT=5173

# Auth0 (optional)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Google OAuth (must match redirect URI in Google Cloud Console)
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
VITE_GOOGLE_CLIENT_ID=

# YouTube API (optional)
VITE_YOUTUBE_API_KEY=
